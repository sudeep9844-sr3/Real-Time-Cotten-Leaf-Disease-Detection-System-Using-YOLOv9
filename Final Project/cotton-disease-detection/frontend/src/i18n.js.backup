            "rec.prev_balanced_fertilization.title": "संतुलित उर्वरक",
            "rec.prev_balanced_fertilization.desc": "अत्यधिक नाइट्रोजन से बचें। संतुलित एनपीके अनुपात बनाए रखें।",

            // Recommendations - Fusarium Wilt
            "rec.chem_carbendazim.title": "कार्बेंडाजिम",
            "rec.chem_carbendazim.desc": "2 ग्राम/लीटर कार्बेंडाजिम 50% डब्ल्यूपी के साथ मिट्टी को गीला करें। जड़ क्षेत्र में लागू करें।",
            "rec.chem_thiophanate.title": "थियोफेनेट मिथाइल",
            "rec.chem_thiophanate.desc": "1.5 ग्राम/लीटर पर मिट्टी के ड्रेन्च के रूप में लागू करें। प्रभावी प्रणालीगत कवकनाशी।",
            "rec.org_trichoderma.title": "ट्राइकोडर्मा विरिडे",
            "rec.org_trichoderma.desc": "जैव नियंत्रण कवक। 5 ग्राम/किग्रा बीज उपचार या 5 किग्रा/हेक्टेयर मिट्टी आवेदन लागू करें।",
            "rec.org_neem_cake.title": "नीम की खली",
            "rec.org_neem_cake.desc": "250 किग्रा/हेक्टेयर पर नीम की खली लागू करें। मिट्टी से होने वाले रोगजनकों को दबाने में मदद करता है।",
            "rec.prev_resistant_varieties.title": "प्रतिरोधी किस्में",
            "rec.prev_resistant_varieties.desc": "बीटी कपास संकर जैसी विल्ट-प्रतिरोधी कपास की किस्में लगाएं।",
            "rec.prev_soil_solarization.title": "मृदा सौरकरण",
            "rec.prev_soil_solarization.desc": "रोगजनकों को मारने के लिए गर्मियों में 4-6 सप्ताह के लिए पारदर्शी प्लास्टिक के साथ मिट्टी को कवर करें।",
            "rec.prev_proper_drainage.title": "उचित जल निकासी",
            "rec.prev_proper_drainage.desc": "अच्छी जल निकासी सुनिश्चित करें। जलभराव से बचें जो फ्यूजेरियम के पक्ष में है।",
            "rec.prev_ph_management.title": "पीएच प्रबंधन",
            "rec.prev_ph_management.desc": "मिट्टी का पीएच 6.5-7.5 बनाए रखें। फ्यूजेरियम अम्लीय मिट्टी में पनपता है।",

            // Recommendations - Leaf Curl Virus
            "rec.chem_imidacloprid.title": "इमिडाक्लोप्रिड",
            "rec.chem_imidacloprid.desc": "0.5 मिली/लीटर पर इमिडाक्लोप्रिड 17.8% एसएल के साथ सफेद मक्खी वेक्टर को नियंत्रित करें।",
            "rec.chem_thiamethoxam.title": "थियामेथोक्साम",
            "rec.chem_thiamethoxam.desc": "सफेद मक्खी नियंत्रण के लिए प्रणालीगत कीटनाशक। 0.2 ग्राम/लीटर पर लागू करें।",
            "rec.org_neem_garlic.title": "नीम तेल + लहसुन का अर्क",
            "rec.org_neem_garlic.desc": "5 मिली नीम का तेल + 10 मिली लहसुन का अर्क प्रति लीटर मिलाएं। सफेद मक्खियों को दूर भगाता है।",
            "rec.org_yellow_traps.title": "पीले चिपचिपे जाल",
            "rec.org_yellow_traps.desc": "सफेद मक्खियों की निगरानी और फंसाने के लिए 15-20 जाल/एकड़ पर पीले चिपचिपे जाल स्थापित करें।",
            "rec.prev_virus_free_seedlings.title": "वायरस मुक्त पौधे",
            "rec.prev_virus_free_seedlings.desc": "अधिकृत नर्सरी से प्रमाणित वायरस मुक्त रोपण सामग्री का उपयोग करें।",
            "rec.prev_remove_infected.title": "संक्रमित पौधों को हटा दें",
            "rec.prev_remove_infected.desc": "फैलाव को रोकने के लिए संक्रमित पौधों को तुरंत उखाड़ फेंके और नष्ट कर दें।",
            "rec.prev_barrier_crops.title": "अवरोधक फसलें",
            "rec.prev_barrier_crops.desc": "कपास के खेतों के चारों ओर मक्का या ज्वार को अवरोधक फसलों के रूप में लगाएं।",
            "rec.prev_weed_management.title": "खरपतवार प्रबंधन",
            "rec.prev_weed_management.desc": "खरपतवारों को नियंत्रित करें जो सफेद मक्खियों के लिए वैकल्पिक मेजबान के रूप में कार्य करते हैं।",

            // Recommendations - Healthy
            "rec.prev_good_practices.title": "अच्छी प्रथाएं जारी रखें",
            "rec.prev_good_practices.desc": "वर्तमान कृषि प्रथाओं को बनाए रखें। नियमित निगरानी महत्वपूर्ण है।",
            "rec.prev_preventive_sprays.title": "निवारक स्प्रे",
            "rec.prev_preventive_sprays.desc": "रोग-प्रवण मौसमों के दौरान निवारक कवकनाशी लागू करें।",
            "rec.prev_nutrient_management.title": "पोषक तत्व प्रबंधन",
            "rec.prev_nutrient_management.desc": "पौधों के स्वास्थ्य और रोग प्रतिरोध को बनाए रखने के लिए संतुलित पोषण सुनिश्चित करें।",
        }
