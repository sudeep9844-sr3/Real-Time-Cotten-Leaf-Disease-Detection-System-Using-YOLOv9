# Environment variables for backend configuration

# Model configuration
MODEL_WEIGHTS=weights/best.pt
MODEL_TYPE=pytorch

# Inference settings
CONF_THRESHOLD=0.25
IOU_THRESHOLD=0.7
IMG_SIZE=640

# Device ('' for auto, 'cpu', '0' for GPU 0)
DEVICE=

# API settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# CORS (comma-separated origins, * for all)
ALLOWED_ORIGINS=*

# File upload
MAX_FILE_SIZE=10485760

# Logging
LOG_LEVEL=INFO

# Google Gemini API for AI-powered recommendations
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
